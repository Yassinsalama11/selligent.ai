generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────

model Tenant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  plan          String   @default("starter") @db.VarChar(50)
  status        String   @default("active") @db.VarChar(50)
  settings      Json     @default("{}")
  knowledgeBase Json     @default("{}") @map("knowledge_base")
  dataResidency String   @default("us") @map("data_residency") @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  users              User[]
  channelConnections ChannelConnection[]
  customers          Customer[]
  conversations      Conversation[]
  messages           Message[]
  deals              Deal[]
  aiSuggestions      AiSuggestion[]
  products           Product[]
  shippingZones      ShippingZone[]
  offers             Offer[]
  integrations       Integration[]
  auditLogs          AuditLog[]
  promptVersions     PromptVersion[]
  promptPins         TenantPromptPin[]
  ingestionJobs      IngestionJob[]
  knowledgeChunks    KnowledgeChunk[]
  tenantProfile      TenantProfile?
  migrationJobs      MigrationJob[]
  reportDaily        ReportDaily[]
  reportAgentDaily   ReportAgentDaily[]
  tokenBudgets       TenantTokenBudget[]
  aiCallLogs         AiCallLog[]
  actionAudits       ActionAudit[]
  encryptionKey      TenantEncryptionKey?
  retentionPolicy    RetentionPolicy?
  privacyJobs        PrivacyJob[]
  evalScores         MessageEvalScore[]
  corrections        ReplyCorrection[]
  memory             TenantMemory[]
  copilotLogs        CopilotLog[]

  @@map("tenants")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String?  @db.VarChar(255)
  role         String   @default("agent") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz()

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedConversations Conversation[]
  reportAgentDaily    ReportAgentDaily[]

  @@unique([tenantId, email])
  @@map("users")
}

model ChannelConnection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  channel     String   @db.VarChar(50)
  status      String   @default("active") @db.VarChar(50)
  credentials Json
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel])
  @@map("channel_connections")
}

model Customer {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  channelCustomerId String   @map("channel_customer_id") @db.VarChar(255)
  channel           String   @db.VarChar(50)
  name              String?  @db.VarChar(255)
  phone             String?  @db.VarChar(50)
  email             String?  @db.VarChar(255)
  avatarUrl         String?  @map("avatar_url")
  tags              Json     @default("[]")
  purchaseHistory   Json     @default("[]") @map("purchase_history")
  preferences       Json     @default("{}")
  totalSpent        Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz()

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  deals         Deal[]

  @@unique([tenantId, channelCustomerId, channel])
  @@map("customers")
}

model Conversation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  channel    String   @db.VarChar(50)
  status     String   @default("open") @db.VarChar(50)
  assignedTo String?  @map("assigned_to") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz()

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id])
  assignedUser User?         @relation(fields: [assignedTo], references: [id])
  messages     Message[]
  deals        Deal[]
  aiSuggestions AiSuggestion[]

  @@index([tenantId])
  @@index([updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  direction      String   @db.VarChar(20)
  type           String   @default("text") @db.VarChar(50)
  content        String?
  mediaUrl       String?  @map("media_url")
  sentBy         String   @default("customer") @map("sent_by") @db.VarChar(50)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  conversation  Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiSuggestions AiSuggestion[]
  evalScores    MessageEvalScore[]
  corrections   ReplyCorrection[]

  @@index([conversationId])
  @@map("messages")
}

model Deal {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  customerId     String?   @map("customer_id") @db.Uuid
  stage          String    @default("new_lead") @db.VarChar(50)
  intent         String?   @db.VarChar(100)
  leadScore      Int       @default(0) @map("lead_score")
  estimatedValue Decimal?  @map("estimated_value") @db.Decimal(12, 2)
  probability    Int       @default(0)
  currency       String    @default("USD") @db.VarChar(10)
  notes          String?
  closedAt       DateTime? @map("closed_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])

  @@index([tenantId, stage])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("deals")
}

model AiSuggestion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  messageId      String?  @map("message_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  suggestedReply String   @map("suggested_reply")
  intent         String?  @db.VarChar(100)
  leadScore      Int?     @map("lead_score")
  confidence     Decimal? @db.Decimal(3, 2)
  wasUsed        Boolean  @default(false) @map("was_used")
  wasEdited      Boolean  @default(false) @map("was_edited")
  finalReply     String?  @map("final_reply")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message      Message?      @relation(fields: [messageId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  corrections  ReplyCorrection[]

  @@map("ai_suggestions")
}

// ─────────────────────────────────────────
// PRODUCT CATALOG
// ─────────────────────────────────────────

model Product {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  externalId    String?   @map("external_id") @db.VarChar(255)
  source        String    @default("manual") @db.VarChar(50)
  name          String    @db.VarChar(500)
  description   String?
  price         Decimal?  @db.Decimal(12, 2)
  salePrice     Decimal?  @map("sale_price") @db.Decimal(12, 2)
  currency      String    @default("USD") @db.VarChar(10)
  stockStatus   String    @default("in_stock") @map("stock_status") @db.VarChar(50)
  stockQuantity Int?      @map("stock_quantity")
  images        Json      @default("[]")
  variants      Json      @default("[]")
  categories    Json      @default("[]")
  sku           String?   @db.VarChar(255)
  weight        Decimal?  @db.Decimal(8, 2)
  shippingInfo  Json      @default("{}") @map("shipping_info")
  metadata      Json      @default("{}")
  isActive      Boolean   @default(true) @map("is_active")
  lastSyncedAt  DateTime? @map("last_synced_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId, source])
  @@index([tenantId])
  @@index([tenantId, source])
  @@map("products")
}

model ShippingZone {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  name                  String   @db.VarChar(255)
  countries             Json     @default("[]")
  regions               Json     @default("[]")
  rates                 Json     @default("[]")
  freeShippingThreshold Decimal? @map("free_shipping_threshold") @db.Decimal(12, 2)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("shipping_zones")
}

model Offer {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  externalId     String?   @map("external_id") @db.VarChar(255)
  source         String    @default("manual") @db.VarChar(50)
  name           String    @db.VarChar(255)
  type           String    @db.VarChar(50)
  value          Decimal?  @db.Decimal(10, 2)
  code           String?   @db.VarChar(100)
  appliesTo      Json      @default("{}") @map("applies_to")
  minOrderValue  Decimal?  @map("min_order_value") @db.Decimal(12, 2)
  usageLimit     Int?      @map("usage_limit")
  usageCount     Int       @default(0) @map("usage_count")
  startsAt       DateTime? @map("starts_at") @db.Timestamptz()
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz()
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("offers")
}

model Integration {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  type       String    @db.VarChar(50)
  status     String    @default("active") @db.VarChar(50)
  config     Json
  lastSyncAt DateTime? @map("last_sync_at") @db.Timestamptz()
  syncStatus String    @default("idle") @map("sync_status") @db.VarChar(50)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("integrations")
}

// ─────────────────────────────────────────
// AUDIT, PROMPTS, KNOWLEDGE
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  actorType  String   @map("actor_type") @db.VarChar(50)
  actorId    String?  @map("actor_id") @db.VarChar(255)
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.VarChar(255)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_log")
}

model PromptVersion {
  tenantId   String   @map("tenant_id") @db.Uuid
  id         String   @db.VarChar(120)
  version    String   @db.VarChar(32)
  promptHash String   @map("prompt_hash") @db.VarChar(64)
  content    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pins   TenantPromptPin[]

  @@id([tenantId, id, version])
  @@index([tenantId, id, createdAt(sort: Desc)])
  @@map("prompt_versions")
}

model TenantPromptPin {
  tenantId  String   @map("tenant_id") @db.Uuid
  promptId  String   @map("prompt_id") @db.VarChar(120)
  version   String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion @relation(fields: [tenantId, promptId, version], references: [tenantId, id, version], onDelete: Cascade)

  @@id([tenantId, promptId])
  @@map("tenant_prompt_pins")
}

model IngestionJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  sourceUrl    String   @map("source_url")
  status       String   @default("queued") @db.VarChar(50)
  pagesSeen    Int      @default(0) @map("pages_seen")
  chunksStored Int      @default(0) @map("chunks_stored")
  error        String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeChunks KnowledgeChunk[]
  tenantProfile  TenantProfile?

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("ingestion_jobs")
}

model KnowledgeChunk {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  jobId       String?  @map("job_id") @db.Uuid
  sourceUrl   String   @map("source_url")
  title       String?
  heading     String?
  contentHash String   @map("content_hash") @db.VarChar(64)
  content     String
  tokenCount  Int      @default(0) @map("token_count")
  embedding   Json     @default("[]")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    IngestionJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([tenantId, contentHash])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("knowledge_chunks")
}

model TenantProfile {
  tenantId    String    @id @map("tenant_id") @db.Uuid
  sourceJobId String?   @map("source_job_id") @db.Uuid
  profile     Json      @default("{}")
  status      String    @default("draft") @db.VarChar(50)
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceJob IngestionJob? @relation(fields: [sourceJobId], references: [id], onDelete: SetNull)

  @@map("tenant_profiles")
}

model MigrationJob {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  provider        String   @db.VarChar(50)
  status          String   @default("queued") @db.VarChar(50)
  externalAccount String?  @map("external_account")
  importedCounts  Json     @default("{}") @map("imported_counts")
  error           String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("migration_jobs")
}

// ─────────────────────────────────────────
// REPORTING
// ─────────────────────────────────────────

model ReportDaily {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  date                 DateTime @db.Date
  channel              String?  @db.VarChar(50)
  totalConversations   Int      @default(0) @map("total_conversations")
  newLeads             Int      @default(0) @map("new_leads")
  dealsWon             Int      @default(0) @map("deals_won")
  dealsLost            Int      @default(0) @map("deals_lost")
  revenueWon           Decimal  @default(0) @map("revenue_won") @db.Decimal(12, 2)
  avgLeadScore         Decimal? @map("avg_lead_score") @db.Decimal(5, 2)
  aiSuggestionsSent    Int      @default(0) @map("ai_suggestions_sent")
  aiSuggestionsUsed    Int      @default(0) @map("ai_suggestions_used")
  aiSuggestionsEdited  Int      @default(0) @map("ai_suggestions_edited")
  humanReplies         Int      @default(0) @map("human_replies")
  avgResponseTime      Int?     @map("avg_response_time_seconds")
  conversionRate       Decimal? @map("conversion_rate") @db.Decimal(5, 2)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, channel])
  @@index([tenantId, date(sort: Desc)])
  @@map("report_daily")
}

model ReportAgentDaily {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  date                DateTime @db.Date
  dealsClosed         Int      @default(0) @map("deals_closed")
  revenueClosed       Decimal  @default(0) @map("revenue_closed") @db.Decimal(12, 2)
  conversationsHandled Int     @default(0) @map("conversations_handled")
  avgResponseTime     Int?     @map("avg_response_time_seconds")
  conversionRate      Decimal? @map("conversion_rate") @db.Decimal(5, 2)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, date])
  @@index([tenantId, date(sort: Desc)])
  @@map("report_agent_daily")
}

// ─────────────────────────────────────────
// AI COST CONTROLS (Task 0-C3)
// ─────────────────────────────────────────

model TenantTokenBudget {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  dailyCap     Int      @map("daily_cap")
  monthlyCap   Int      @map("monthly_cap")
  dailyUsed    Int      @default(0) @map("daily_used")
  monthlyUsed  Int      @default(0) @map("monthly_used")
  lastResetDay DateTime @default(now()) @map("last_reset_day") @db.Date
  lastResetMonth DateTime @default(now()) @map("last_reset_month") @db.Date
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@map("tenant_token_budgets")
}

model AiCallLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  model          String   @db.VarChar(100)
  promptHash     String   @map("prompt_hash") @db.VarChar(64)
  tokensIn       Int      @map("tokens_in")
  tokensOut      Int      @map("tokens_out")
  latencyMs      Int      @map("latency_ms")
  conversationId String?  @map("conversation_id") @db.Uuid
  status         String   @default("success") @db.VarChar(20)
  error          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("ai_call_logs")
}

// ─────────────────────────────────────────
// ACTION SDK (Task 0-C5)
// ─────────────────────────────────────────

// ─────────────────────────────────────────
// PII ENCRYPTION (Task 1-C2)
// ─────────────────────────────────────────

model TenantEncryptionKey {
  tenantId   String   @id @map("tenant_id") @db.Uuid
  encDek     String   @map("enc_dek")
  keyVersion Int      @default(1) @map("key_version")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_encryption_keys")
}

// ─────────────────────────────────────────
// RETENTION & DSR (Task 1-C4)
// ─────────────────────────────────────────

model RetentionPolicy {
  tenantId          String   @id @map("tenant_id") @db.Uuid
  messagesDays      Int      @default(365)  @map("messages_days")
  conversationsDays Int      @default(730)  @map("conversations_days")
  auditLogDays      Int      @default(2555) @map("audit_log_days")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

